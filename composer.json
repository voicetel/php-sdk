{
    "name": "voicetel/sdk",
    "description": "Official PHP SDK for the VoiceTel REST API (v2.2.10).",
    "type": "library",
    "version": "2.2.10",
    "keywords": ["voicetel", "sdk", "voip", "telephony", "sms", "mms", "did", "e911", "10dlc"],
    "homepage": "https://voicetel.com",
    "license": "MIT",
    "authors": [
        {
            "name": "VoiceTel",
            "email": "support@voicetel.com",
            "homepage": "https://voicetel.com"
        }
    ],
    "support": {
        "issues": "https://github.com/voicetel/php-sdk/issues",
        "source": "https://github.com/voicetel/php-sdk",
        "docs": "https://voicetel.com/docs/api/v2.2/"
    },
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "VoiceTel\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VoiceTel\\Sdk\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text --coverage-clover=clover.xml",
        "phpstan": "phpstan analyse"
    },
    "minimum-stability": "stable"
}
